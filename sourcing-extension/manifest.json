{
  "manifest_version": 3,
  "name": "참아야하느니라 소싱툴",
  "version": "1.1",
  "description": "알리익스프레스/쿠팡 상품 소싱 및 큐 관리",
  "permissions": ["activeTab", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "참아야하느니라 소싱툴"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.aliexpress.com/item/*",
        "https://*.aliexpress.us/item/*",
        "https://www.coupang.com/vp/products/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
