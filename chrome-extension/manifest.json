{
  "manifest_version": 3,
  "name": "참아야하느니라 미디어툴",
  "version": "1.0.0",
  "description": "알리익스프레스 슬라이드쇼 생성 + 영상 자르기 도구",
  "action": {
    "default_title": "참아야하느니라 미디어툴"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://*.aliexpress.com/*",
    "https://*.aliexpress.us/*",
    "https://*.alicdn.com/*",
    "https://ae01.alicdn.com/*",
    "https://ae02.alicdn.com/*",
    "https://ae03.alicdn.com/*",
    "https://ae04.alicdn.com/*",
    "https://img.alicdn.com/*",
    "https://cbu01.alicdn.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["newtab.html", "newtab.css", "newtab.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
